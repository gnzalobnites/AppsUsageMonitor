<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="Apariencia">
        <ListPreference
            app:defaultValue="system"
            app:entries="@array/theme_entries"
            app:entryValues="@array/theme_values"
            app:key="theme_mode"
            app:title="Tema"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            app:defaultValue="es"
            app:entries="@array/language_entries"
            app:entryValues="@array/language_values"
            app:key="language"
            app:title="Idioma"
            app:useSimpleSummaryProvider="true" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Notificaciones">
        <SwitchPreferenceCompat
            app:defaultValue="true"
            app:key="persistent_notification"
            app:title="Notificación persistente"
            app:summary="Mantener icono en la barra de estado mientras se monitorea" />
    </PreferenceCategory>

</PreferenceScreen>

