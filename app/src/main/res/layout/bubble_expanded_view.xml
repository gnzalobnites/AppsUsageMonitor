<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/expanded_container"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_elegant_bubble"
    android:elevation="12dp"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/current_session_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/current_session_label"
        android:textSize="14sp"
        android:textColor="#E6FFFFFF"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/current_session_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/current_session_time_format"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:shadowColor="#33000000"
        android:shadowDx="0"
        android:shadowDy="4"
        android:shadowRadius="8"
        android:layout_marginBottom="16dp"/>

    <ProgressBar
        android:id="@+id/session_progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:progressDrawable="@drawable/custom_progress_bar"
        android:max="100"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/total_today_label"
        android:textSize="12sp"
        android:textColor="#B3FFFFFF"/>

    <TextView
        android:id="@+id/total_today_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/total_today_time_format"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/close_button"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="@string/continue_button"
        android:textAllCaps="false"
        app:backgroundTint="#33FFFFFF"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:cornerRadius="25dp"
        style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

</LinearLayout>