<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/expanded_outer"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_elegant_bubble"
    android:elevation="12dp"
    android:clipToOutline="true">

    <!-- Brillo superior tipo "glass". Plano (sin esquinas propias): se
         recorta a las esquinas reales de bg_elegant_bubble gracias a
         clipToOutline en el contenedor, así no depende de adivinar su radio. -->
    <View
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_glass_highlight_overlay" />

    <LinearLayout
        android:id="@+id/expanded_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/current_session_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/current_session_label"
            android:textSize="14sp"
            android:textColor="#E6FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp"/>

        <!-- Tiempo de sesión: ícono chico + número grande, mismo color de
             estado que la burbuja colapsada (normal/cerca de meta/alarma/extra) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/session_time_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="6dp"
                android:src="@drawable/ic_clock_small"
                android:contentDescription="@null"/>

            <TextView
                android:id="@+id/current_session_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/current_session_time_format"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:shadowColor="#33000000"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="8"/>

        </LinearLayout>

        <!-- Meta de tiempo -->
        <TextView
            android:id="@+id/goal_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/goal_progress_label"
            android:textSize="12sp"
            android:textColor="#B3FFFFFF"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/goal_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/goal_progress_format"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <ProgressBar
            android:id="@+id/session_progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:progressDrawable="@drawable/custom_progress_bar"
            android:max="100"
            android:layout_marginBottom="16dp"/>

        <!-- Tiempo total de pantalla -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bubble_today_screen_label"
            android:textSize="12sp"
            android:textColor="#B3FFFFFF"/>

        <TextView
            android:id="@+id/total_today_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/total_today_time_format"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <!-- Icono de meta alcanzada (inicialmente invisible) -->
        <ImageView
            android:id="@+id/goal_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_goal_reached"
            android:visibility="gone"
            android:layout_marginBottom="8dp"
            android:contentDescription="@string/app_icon_description"/>

        <!-- ===== UI DE TIEMPO EXTRA ===== -->
        <!-- Estado de la meta -->
        <TextView
            android:id="@+id/extras_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/goal_reached_title"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:visibility="gone"
            android:gravity="center_horizontal"
            android:layout_marginBottom="4dp"/>

        <!-- Tiempo total acumulado -->
        <TextView
            android:id="@+id/extras_total_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/goal_extras_total_time"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:visibility="gone"
            android:layout_marginBottom="4dp"/>

        <!-- Bloques extra agregados -->
        <TextView
            android:id="@+id/extras_blocks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/goal_extras_blocks"
            android:textSize="14sp"
            android:textColor="#B3FFFFFF"
            android:visibility="gone"
            android:layout_marginBottom="12dp"/>

        <!-- Botón: Agregar +5 min Extra (acción primaria: lleno) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_extras"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/goal_extras_add_5min"
            android:textAllCaps="false"
            app:backgroundTint="#FFD700"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="24dp"
            android:visibility="gone"
            android:layout_marginBottom="8dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <!-- Botón: Cerrar la app monitoreada (acción secundaria/seria: outline,
             para no competir en peso visual con "Agregar 5 min") -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_close_app"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Cerrar app"
            android:textAllCaps="false"
            app:strokeColor="#E53935"
            app:strokeWidth="1.5dp"
            android:textColor="#E53935"
            android:textSize="14sp"
            app:cornerRadius="24dp"
            android:visibility="gone"
            android:layout_marginBottom="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <!-- Botón: Colapsar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_collapse"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/collapse_bubble"
            android:textAllCaps="false"
            app:backgroundTint="#33FFFFFF"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            app:cornerRadius="24dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

    </LinearLayout>

</FrameLayout>
