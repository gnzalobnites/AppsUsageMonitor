<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="6dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Halo/glow: círculo más grande y difuso detrás del principal.
         Tamaño y color los fija BubbleService.applyBubbleVisualState()
         en tiempo de ejecución, según el diámetro y el estado actual. -->
    <View
        android:id="@+id/bubble_glow"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_gravity="center" />

    <!-- Círculo principal: gradiente radial + brillo superior (glass),
         color dinámico según el estado (normal / cerca de meta / alarma /
         tiempo extra activo). El fondo también lo fija BubbleService. -->
    <FrameLayout
        android:id="@+id/bubble_container"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_bubble_circle"
        android:elevation="8dp">

        <TextView
            android:id="@+id/badge_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:text="0m"
            android:maxLines="1"
            android:shadowColor="#55000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="4"/>

    </FrameLayout>

</FrameLayout>
