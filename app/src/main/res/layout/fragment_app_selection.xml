<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	android:background="?android:attr/windowBackground"
	android:padding="16dp">

	<TextView
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:text="@string/select_interval"
		android:textSize="16sp"
		android:textStyle="bold"
		android:textColor="?attr/colorOnSurface"
		android:layout_marginBottom="8dp" />

	<Spinner
		android:id="@+id/spinner_interval"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:backgroundTint="?attr/colorOnSurface"
		android:dropDownSelector="?attr/colorPrimary"
		android:popupBackground="?attr/colorSurface" />

	<TextView
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:text="@string/select_apps_title"
		android:textSize="16sp"
		android:textStyle="bold"
		android:textColor="?attr/colorOnSurface"
		android:layout_marginTop="16dp"
		android:layout_marginBottom="8dp" />

	<EditText
		android:id="@+id/edit_search"
		android:layout_width="match_parent"
		android:layout_height="48dp"
		android:hint="@string/search_apps_hint"
		android:padding="12dp"
		android:drawableStart="@android:drawable/ic_menu_search"
		android:drawablePadding="8dp"
		android:textColorHint="?attr/colorControlNormal"
		android:textColor="?attr/colorOnSurface"
		android:backgroundTint="?attr/colorPrimary"
		android:background="?attr/colorSurface"
		android:layout_marginBottom="16dp" />

	<androidx.recyclerview.widget.RecyclerView
		android:id="@+id/recycler_view_apps"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_weight="1"
		android:background="?attr/colorSurface"
		android:elevation="2dp" />

	<Button
		android:id="@+id/button_add_selected"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:text="@string/add_selected"
		android:backgroundTint="?attr/colorPrimary"
		android:textColor="?attr/colorOnPrimary"
		android:textSize="16sp"
		android:padding="12dp"
		android:layout_marginTop="16dp" />

	<android.view.View
		android:layout_width="match_parent"
		android:layout_height="1dp"
		android:background="?android:attr/listDivider"
		android:layout_marginVertical="16dp" />

	<TextView
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:text="@string/monitored_apps_title"
		android:textSize="16sp"
		android:textStyle="bold"
		android:textColor="?attr/colorOnSurface"
		android:layout_marginBottom="8dp" />

	<androidx.recyclerview.widget.RecyclerView
		android:id="@+id/recycler_view_monitored_apps"
		android:layout_width="match_parent"
		android:layout_height="200dp"
		android:nestedScrollingEnabled="true"
		android:background="?attr/colorSurface"
		android:elevation="2dp"
		android:layout_marginBottom="8dp" />

	<TextView
		android:id="@+id/tv_empty_monitored"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:text="@string/no_monitored_apps"
		android:textSize="14sp"
		android:textColor="?android:attr/textColorSecondary"
		android:gravity="center"
		android:padding="16dp"
		android:visibility="gone" />

</LinearLayout>